VITE_SOLANA_CLUSTER=localnet

# Legacy single-headless-wallet mode
VITE_HEADLESS_WALLET_SECRET_KEY=
VITE_HEADLESS_WALLET_NAME=Headless Test Wallet
VITE_HEADLESS_WALLET_AUTO_CONNECT=false

# Multi-headless-wallet mode (JSON array). Takes precedence when set.
# Example:
# VITE_HEADLESS_WALLETS=[{"name":"MM Wallet 1","secretKey":"<bs58-or-json-bytes>","autoConnect":true},{"name":"MM Wallet 2","secretKey":"<bs58-or-json-bytes>"}]
# Tip: generate this from market-maker config with
# `bun run --cwd /Users/sasankchunduri/hyperscape/packages/market-maker-bot wallets:ui-env -- --config wallets.generated.json --out ../gold-betting-demo/app/.env.local`
VITE_HEADLESS_WALLETS=
